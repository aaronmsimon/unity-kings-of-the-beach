                    <ui:VisualElement class="team-logo" style="flex-grow: 1; background-image: resource(&apos;Textures/Teams/Countries/USA&apos;); -unity-background-scale-mode: scale-to-fit; max-width: 100px;" />
                    <ui:VisualElement class="trigger-right" style="flex-grow: 1; background-image: url(&quot;project://database/Assets/Textures/UI Icons/xbox_rt.png?fileID=2800000&amp;guid=9ba8bcdca5ac73d4baec1e2b8717b8b6&amp;type=3#xbox_rt&quot;); -unity-background-scale-mode: scale-to-fit; max-width: 40px; margin-left: 5px;" />
