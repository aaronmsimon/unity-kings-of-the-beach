                    <ui:VisualElement class="trigger-left" style="flex-grow: 1; background-image: url(&quot;project://database/Assets/Textures/UI Icons/xbox_lt.png?fileID=2800000&amp;guid=64c6cd96baf6d204bb77f3c3503f54d5&amp;type=3#xbox_lt&quot;); -unity-background-scale-mode: scale-to-fit; max-width: 40px; margin-right: 5px;" />
