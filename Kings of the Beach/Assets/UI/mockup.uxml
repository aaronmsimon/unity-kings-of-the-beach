<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI/AthleteSelectMenu.uss?fileID=7433441132597879392&amp;guid=234d28f9bfd7879438c1b4d58389f753&amp;type=3#AthleteSelectMenu" />
    <ui:VisualElement name="root" style="flex-grow: 1; align-items: center; justify-content: center; width: 100%; height: 100%;">
        <ui:VisualElement name="athlete-grid" style="width: 80%; height: 80%; justify-content: center; align-items: center; flex-direction: row;">
            <ui:VisualElement style="flex-grow: 1; height: 100%;">
                <ui:VisualElement style="flex-grow: 1; max-height: 10%;" />
                <ui:VisualElement style="flex-grow: 1; justify-content: center; max-height: 45%;">
                    <ui:Label tabindex="-1" text="Blocker" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Label" style="rotate: -90deg; font-size: 25px;" />
                </ui:VisualElement>
                <ui:VisualElement style="flex-grow: 1; justify-content: center; max-height: 45%;">
                    <ui:Label tabindex="-1" text="Defender" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Label" style="rotate: -90deg; font-size: 25px;" />
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="team">
                <ui:VisualElement name="team-name-1" style="flex-grow: 1; max-height: 10%; flex-direction: row; justify-content: center;">
                    <ui:VisualElement class="grow input-lt" />
                    <ui:VisualElement class="team-logo" style="flex-grow: 1; background-image: resource(&apos;Textures/Teams/Countries/USA&apos;); -unity-background-scale-mode: scale-to-fit; max-width: 100px;" />
                    <ui:VisualElement class="grow input-rt" />
                </ui:VisualElement>
                <ui:VisualElement name="athlete-1" style="flex-grow: 1; flex-direction: column; max-height: 45%;">
                    <ui:VisualElement name="VisualElement" style="flex-direction: row;">
                        <ui:VisualElement name="VisualElement" style="flex-grow: 1; background-image: url(&quot;project://database/Assets/Textures/Render/Athlete1RenderTexture.renderTexture?fileID=8400000&amp;guid=eb03d7bcdba6a0647a88b13c9d81b680&amp;type=2#Athlete1RenderTexture&quot;); -unity-background-scale-mode: scale-to-fit; display: none;" />
                        <ui:VisualElement style="flex-grow: 1; flex-direction: row;">
                            <ui:VisualElement class="stats-names" style="flex-grow: 1; flex-direction: column;">
                                <ui:Label text="Pass Accuracy" style="font-size: 10px;" />
                                <ui:Label text="Spike Skill" style="font-size: 10px;" />
                                <ui:Label text="Spike Power" style="font-size: 10px;" />
                                <ui:Label text="Serve Skill" style="font-size: 10px;" />
                                <ui:Label text="Serve Power" style="font-size: 10px;" />
