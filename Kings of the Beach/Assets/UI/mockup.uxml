                                <ui:VisualElement class="stat-bar" style="width: 100%; height: 12px; background-color: rgba(255, 255, 255, 0.2); border-radius: 4px;">
                                    <ui:VisualElement class="stat-bar-fill" style="height: 100%; background-color: white; border-radius: 4px; width: 50%;"/>
                                </ui:VisualElement>
                                <ui:VisualElement class="stat-bar" style="width: 100%; height: 12px; background-color: rgba(255, 255, 255, 0.2); border-radius: 4px;">
                                    <ui:VisualElement class="stat-bar-fill" style="height: 100%; background-color: white; border-radius: 4px; width: 25%;"/>
                                </ui:VisualElement>
